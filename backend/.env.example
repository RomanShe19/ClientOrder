# Database (async driver for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://autovip:CHANGE_ME_postgres_password@postgres:5432/autovip

# Application
SECRET_KEY=CHANGE_ME_random_secret_key
APP_ENV=production

# Connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=3
DB_POOL_RECYCLE=1800

# CORS (JSON list of allowed origins)
CORS_ORIGINS=["http://localhost", "https://your-domain.com"]

# JWT Authentication
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_minimum_32_characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
