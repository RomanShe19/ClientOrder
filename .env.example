# ===== PostgreSQL =====
POSTGRES_DB=autovip
POSTGRES_USER=autovip
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# ===== pgAdmin =====
PGADMIN_EMAIL=admin@autovip.io
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password

# ===== Nginx Basic Auth (pgAdmin gateway) =====
NGINX_ADMIN_USER=admin
NGINX_ADMIN_PASSWORD=CHANGE_ME_nginx_admin_password

# ===== Docker Registry =====
REGISTRY_USER=deployer
REGISTRY_PASSWORD=CHANGE_ME_registry_password
REGISTRY_HOST=localhost

# ===== Backend =====
SECRET_KEY=CHANGE_ME_random_secret_key

# ===== Watchtower =====
WATCHTOWER_POLL_INTERVAL=300
# Shoutrrr URL для уведомлений (Telegram, Slack и т.д.)
# Пример Telegram: telegram://token@telegram?chats=chatid
WATCHTOWER_NOTIFICATION_URL=
